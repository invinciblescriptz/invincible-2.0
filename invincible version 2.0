local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()
local Window = Rayfield:CreateWindow({
    Name = "Muscle Legends Advanced Script",
    LoadingTitle = "Loading Advanced Features",
    LoadingSubtitle = "Enhance Your Gameplay!",
    ConfigurationSaving = true,
    ConfigurationFolder = "MuscleLegendsAdvanced",
})

-- Variables
local autoTrain = false
local autoCollectOrbs = false
local autoRebirth = false

-- Functions
local function train()
    -- Replace with actual remote event and arguments for training
    game:GetService("ReplicatedStorage").Events.Train:FireServer("Muscle")
end

local function collectOrbs()
    -- Replace with actual code to find and collect orbs
    -- Example: Iterate through all orbs in workspace and collect
    for i, orb in pairs(workspace:GetDescendants()) do
        if orb:IsA("Part") and orb.Name == "Orb" then
            game:GetService("ReplicatedStorage").Events.CollectOrb:FireServer(orb)
        end
    end
end

local function rebirth()
    -- Replace with actual remote event and arguments for rebirth
    game:GetService("ReplicatedStorage").Events.Rebirth:FireServer()
end

-- Tabs
local Main = Window:CreateTab("Main")
local TeleportTab = Window:CreateTab("Teleport")

-- Main Tab Features
local trainSection = Main:CreateSection("Auto Training")
local AutoTrainButton = trainSection:CreateButton({
    Name = "Toggle Auto Train",
    Callback = function()
        autoTrain = not autoTrain
        while autoTrain do
            train()
            wait(1)
        end
    end,
})

local orbsSection = Main:CreateSection("Auto Collect Orbs")
local AutoCollectOrbsButton = orbsSection:CreateButton({
    Name = "Toggle Auto Collect Orbs",
    Callback = function()
        autoCollectOrbs = not autoCollectOrbs
        while autoCollectOrbs do
            collectOrbs()
            wait(5) -- Adjust wait time as needed
        end
    end,
})

local rebirthSection = Main:CreateSection("Auto Rebirth")
local AutoRebirthButton = rebirthSection:CreateButton({
    Name = "Toggle Auto Rebirth",
    Callback = function()
        autoRebirth = not autoRebirth
        while autoRebirth do
            rebirth()
            wait(60) -- Adjust wait time as needed
        end
    end,
})

-- Teleport Tab Features
local teleportSection = TeleportTab:CreateSection("Teleportation")
local ZoneDropdown = teleportSection:CreateDropdown({
    Name = "Select Zone",
    Options = {"Zone1", "Zone2", "Zone3"}, -- Replace with actual zone names
    Callback = function(option)
        -- Implement teleportation logic here
        if option == "Zone1" then
            -- Teleport to Zone1
            game.Players.LocalPlayer.Character:MoveTo(Vector3.new(0, 0, 0)) -- Replace with actual coordinates
        elseif option == "Zone2" then
            -- Teleport to Zone2
            game.Players.LocalPlayer.Character:MoveTo(Vector3.new(100, 0, 100)) -- Replace with actual coordinates
        elseif option == "Zone3" then
            -- Teleport to Zone3
            game.Players.LocalPlayer.Character:MoveTo(Vector3.new(200, 0, 200)) -- Replace with actual coordinates
        end
    end,
})

-- Add more teleport locations
local customTeleportSection = TeleportTab:CreateSection("Custom Teleport")
local XInput = customTeleportSection:CreateInput({
    Name = "X Coordinate",
    PlaceholderText = "Enter X Coordinate",
})
local YInput = customTeleportSection:CreateInput({
    Name = "Y Coordinate",
    PlaceholderText = "Enter Y Coordinate",
})
local ZInput = customTeleportSection:CreateInput({
    Name = "Z Coordinate",
    PlaceholderText = "Enter Z Coordinate",
})
local TeleportButton = customTeleportSection:CreateButton({
    Name = "Teleport to Custom Coordinates",
    Callback = function()
        local x = tonumber(XInput:GetText())
        local y = tonumber(YInput:GetText())
        local z = tonumber(ZInput:GetText())
        if x and y and z then
            game.Players.LocalPlayer.Character:MoveTo(Vector3.new(x, y, z))
        else
            print("Invalid coordinates")
        end
    end,
})

-- Additional Features
local MiscTab = Window:CreateTab("Misc")
local miscSection = MiscTab:CreateSection("Misc Settings")
local SpeedSlider = miscSection:CreateSlider({
    Name = "Walk Speed",
    Min = 16,
    Max = 100,
    Default = 16,
    ValueName = "Speed",
    Callback = function(value)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = value
    end,
})

Rayfield:LoadConfiguration()
