-- Invincible Paid – cleaned & fixed (March 2026 style)

local whitelistedUsers = {
    "hebdjxhc",
    "krxzy_214",
    "alexglover020",
    -- add yourself here if testing
}

local Players        = game:GetService("Players")
local LocalPlayer    = Players.LocalPlayer
local RS             = game:GetService("ReplicatedStorage")
local UIS            = game:GetService("UserInputService")
local RSvc           = game:GetService("RunService")
local VU             = game:GetService("VirtualUser")
local Workspace      = game:GetService("Workspace")

-- Instant kick if not whitelisted
if not table.find(whitelistedUsers, LocalPlayer.Name) then
    LocalPlayer:Kick("Not whitelisted. Don't steal scripts.")
    return
end

-- Try to find common remotes (Muscle Legends often changes names slightly)
local muscleEvent    = RS:WaitForChild("muscleEvent", 8)         -- very common name
local rebirthRemote  = RS:FindFirstChild("rEvents") 
                     and RS.rEvents:FindFirstChild("rebirthRemote") 
                     or RS:FindFirstChild("rebirthRemote", true)

if not muscleEvent then
    warn("Could not find muscleEvent remote – training won't work!")
end

-- UI Library (using your link – make sure it's still alive in 2026)
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/memejames/elerium-v2-ui-library/main/Library"))()
local window = library:AddWindow("Invincible Paid", {
    main_color = Color3.fromRGB(40, 40, 40),
    min_size = Vector2.new(540, 560),
    can_resize = true,
    background_transparency = 0.9,
})

getgenv().NexusRunning = true

local states = {
    AutoPushups     = false,
    AutoWeights     = false,
    AutoHandstands  = false,
    FastPunch       = false,
    FastStrength    = false,
    InfiniteJump    = false,
    AntiAfk         = false,
    KillAura        = false,
    AutoKillTarget  = false,
    AutoRebirth     = false,
    RockFarm        = false,
}

local selectedRockDur   = 0
local selectedTarget    = nil
local targetRebirths    = 1

-- Helper: safe teleport
local function tpTo(pos)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        end
    end)
end

-- Auto rep (pushups / weights / handstands)
local function startAutoTool(toolName, stateKey)
    task.spawn(function()
        while states[stateKey] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                    task.wait(2) return
                end

                local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
                if tool and tool.Parent ~= char then
                    char.Humanoid:EquipTool(tool)
                end

                if muscleEvent then
                    muscleEvent:FireServer("rep")
                end
            end)
            task.wait(0.07)
        end
        -- cleanup
        pcall(function()
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChild(toolName)
            if tool then tool.Parent = LocalPlayer.Backpack end
        end)
    end)
end

-- Fast strength / punch loop
local fastStrConn
local function toggleFastStrength(enable)
    states.FastStrength = enable
    if enable then
        if fastStrConn then fastStrConn:Disconnect() end
        fastStrConn = RSvc.Heartbeat:Connect(function()
            pcall(function()
                if muscleEvent then
                    muscleEvent:FireServer("rep")
                    muscleEvent:FireServer("punch", "rightHand")
                    muscleEvent:FireServer("punch", "leftHand")
                end
                local char = LocalPlayer.Character
                local tool = char and char:FindFirstChildWhichIsA("Tool")
                if tool then tool:Activate() end
            end)
        end)
    else
        if fastStrConn then fastStrConn:Disconnect() fastStrConn = nil end
    end
end

-- Infinite jump
local jumpConn
local function toggleInfJump(enable)
    states.InfiniteJump = enable
    if enable then
        jumpConn = UIS.JumpRequest:Connect(function()
            pcall(function()
                local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState("Jumping") end
            end)
        end)
    else
        if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    end
end

-- Anti-AFK
local antiAfkConn
local function toggleAntiAfk(enable)
    states.AntiAfk = enable
    if enable then
        antiAfkConn = LocalPlayer.Idled:Connect(function()
            VU:CaptureController()
            VU:ClickButton2(Vector2.new())
        end)
    else
        if antiAfkConn then antiAfkConn:Disconnect() antiAfkConn = nil end
    end
end

-- Simple kill (under map style)
local function killPlayer(targetPlr)
    pcall(function()
        local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tHRP = targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart")
        if myHRP and tHRP then
            myHRP.CFrame = tHRP.CFrame * CFrame.new(0, -30, 0)
        end
    end)
end

-- Tabs
local mainTab    = window:AddTab("Main")
local trainTab   = window:AddTab("Training")
local rebirthTab = window:AddTab("Rebirth")
local tpTab      = window:AddTab("Teleport")
local killTab    = window:AddTab("Kill")
local rockTab    = window:AddTab("Rock Farm")
local miscTab    = window:AddTab("Misc")

-- Training folder
local trainFolder = trainTab:AddFolder("Auto Train")
trainFolder:AddSwitch("Auto Pushups",    function(v) states.AutoPushups   = v if v then startAutoTool("Pushups",    "AutoPushups")   end end)
trainFolder:AddSwitch("Auto Weights",    function(v) states.AutoWeights   = v if v then startAutoTool("Weights",    "AutoWeights")   end end)
trainFolder:AddSwitch("Auto Handstands", function(v) states.AutoHandstands = v if v then startAutoTool("Handstands", "AutoHandstands") end end)
trainFolder:AddSwitch("Fast Strength",   function(v) toggleFastStrength(v) end)

-- Misc toggles
local miscFolder = miscTab:AddFolder("Utility")
miscFolder:AddSwitch("Infinite Jump", function(v) toggleInfJump(v) end)
miscFolder:AddSwitch("Anti-AFK",      function(v) toggleAntiAfk(v) end)

-- Teleports (update coords if needed – these are approximate 2025/26)
local tpFolder = tpTab:AddFolder("Areas")
tpFolder:AddButton("Spawn / Safe",      function() tpTo(Vector3.new(-6,   5,  -196)) end)
tpFolder:AddButton("Tiny Island",       function() tpTo(Vector3.new(-39,  6,  1886)) end)
tpFolder:AddButton("Frozen",            function() tpTo(Vector3.new(-2623,6,  -409)) end)
tpFolder:AddButton("Mythical",          function() tpTo(Vector3.new(2251, 6,  1073)) end)
tpFolder:AddButton("Inferno",           function() tpTo(Vector3.new(-6759,6, -1285)) end)
tpFolder:AddButton("Legend",            function() tpTo(Vector3.new(4603, 990,-3898)) end)
tpFolder:AddButton("Muscle King",       function() tpTo(Vector3.new(-8626,16, -5730)) end)

-- Rock farm (very simplified – many games now block touch interest abuse)
local rockFolder = rockTab:AddFolder("Durability Rocks")
rockFolder:AddSwitch("Farm Starter (100)",   function(v) selectedRockDur = v and 100 or 0   end)
rockFolder:AddSwitch("Farm Legend Beach (5k)", function(v) selectedRockDur = v and 5000 or 0 end)
rockFolder:AddSwitch("Farm Frost (150k)",    function(v) selectedRockDur = v and 150000 or 0 end)
-- add more if you want...

task.spawn(function()
    while getgenv().NexusRunning do
        if selectedRockDur <= 0 then task.wait(0.8) continue end

        pcall(function()
            local char = LocalPlayer.Character
            if not char or char.Humanoid.Health <= 0 then task.wait(1.5) return end

            local durVal = LocalPlayer:FindFirstChild("Durability")
            if not durVal or durVal.Value < selectedRockDur then task.wait(0.4) return end

            local punch = char:FindFirstChild("Punch") or LocalPlayer.Backpack:FindFirstChild("Punch")
            if punch and punch.Parent ~= char then char.Humanoid:EquipTool(punch) end

            for _, obj in pairs(Workspace.machinesFolder:GetDescendants()) do
                if obj.Name == "neededDurability" and obj.Value == selectedRockDur then
                    local rock = obj.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        firetouchinterest(rock, char:FindFirstChild("RightHand"), 0) task.wait(0.03) firetouchinterest(rock, char:FindFirstChild("RightHand"), 1)
                        firetouchinterest(rock, char:FindFirstChild("LeftHand"),  0) task.wait(0.03) firetouchinterest(rock, char:FindFirstChild("LeftHand"),  1)
                        if muscleEvent then
                            muscleEvent:FireServer("punch", "leftHand")
                            muscleEvent:FireServer("punch", "rightHand")
                        end
                    end
                end
            end
        end)
        task.wait(0.18)
    end
end)

-- Kill aura
local killAuraConn
killTab:AddSwitch("Kill Aura (All)", function(v)
    states.KillAura = v
    if v then
        killAuraConn = RSvc.Heartbeat:Connect(function()
            if not states.KillAura then return end
            for _, p in Players:GetPlayers() do
                if p ~= LocalPlayer then killPlayer(p) end
            end
        end)
    else
        if killAuraConn then killAuraConn:Disconnect() killAuraConn = nil end
    end
end)

-- Simple target kill (dropdown needs library support)
-- If your UI lib doesn't have good dropdown support → consider switching library

-- Auto Rebirth
rebirthTab:AddSwitch("Auto Rebirth (spam)", function(v)
    states.AutoRebirth = v
    if v then
        task.spawn(function()
            while states.AutoRebirth and getgenv().NexusRunning do
                pcall(function()
                    if rebirthRemote then
                        rebirthRemote:InvokeServer("rebirthRequest") -- most common arg
                    end
                end)
                task.wait(0.15)
            end
        end)
    end
end)

rebirthTab:AddInput("Target Rebirths", "number", function(val)
    local n = tonumber(val)
    if n and n > 0 then targetRebirths = n end
end)

rebirthTab:AddSwitch("Stop at Target", function(v)
    if v then
        task.spawn(function()
            while v and getgenv().NexusRunning do
                local rebirths = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Rebirths")
                if rebirths and rebirths.Value >= targetRebirths then
                    states.AutoRebirth = false
                    v = false -- stop this loop too
                    break
                end
                task.wait(0.5)
            end
        end)
    end
end)

print("Invincible Paid – cleaned & fixed (March 2026)")
print("If training doesn't work → muscleEvent remote most likely changed name.")
