local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()
local Window = Rayfield:CreateWindow({
    Name = "Muscle Legends Utility 2026",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Better safe than banned",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "MuscleLegendsUtility",
        FileName = "Config"
    }
})

-- Services
local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local plr = Players.LocalPlayer

-- Variables
local autoTrain = false
local autoRebirth = false
local autoSell = false
local infiniteJump = false
local walkSpeed = 16
local jumpPower = 50
local antiAFK = false

-- Remote paths (MUST VERIFY THESE YOURSELF - most likely wrong in 2026)
-- Common ones from older/recent scripts:
local remotes = {
    Train = RS:FindFirstChild("Events") and RS.Events:FindFirstChild("Train") 
        or RS:FindFirstChild("TrainStat") 
        or RS:FindFirstChild("TrainEvent"),  -- placeholder - update!
    
    Rebirth = RS:FindFirstChild("Rebirth") 
        or RS.Events:FindFirstChild("Rebirth"),
    
    Sell = RS:FindFirstChild("Sell") 
        or RS.Events:FindFirstChild("SellAll"),
    
    -- Add more if you find them (e.g. ClaimChest, OpenEggType, etc.)
}

-- Functions
local function safeFire(remote, ...)
    if remote and remote:IsA("RemoteEvent") then
        pcall(function()
            remote:FireServer(...)
        end)
    end
end

local function getRoot()
    return plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    return plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
end

-- Auto loops
spawn(function()
    while true do
        wait(0.4 + math.random(0.1, 0.6))  -- jitter to look less bot-like
        
        if autoTrain and remotes.Train then
            safeFire(remotes.Train, "Strength")  -- change to "Agility", "Durability" etc. if needed
        end
        
        if autoSell and remotes.Sell then
            safeFire(remotes.Sell)
        end
    end
end)

spawn(function()
    while true do
        wait(45 + math.random(10, 30))
        if autoRebirth and remotes.Rebirth then
            -- Optional: check strength > some value before rebirth
            safeFire(remotes.Rebirth)
        end
    end
end)

-- Infinite Jump
local infJumpConn
local function setupInfJump()
    if infJumpConn then infJumpConn:Disconnect() end
    if infiniteJump then
        infJumpConn = UIS.JumpRequest:Connect(function()
            local hum = getHumanoid()
            if hum then
                hum:ChangeState("Jumping")
            end
        end)
    end
end

-- UI
local Main = Window:CreateTab("Main Farm")
local PlayerTab = Window:CreateTab("Player")
local MiscTab = Window:CreateTab("Misc")

-- Main Tab
Main:CreateSection("Auto Farm")

Main:CreateToggle({
    Name = "Auto Train (Strength)",
    CurrentValue = false,
    Callback = function(v)
        autoTrain = v
    end
})

Main:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(v)
        autoRebirth = v
    end
})

Main:CreateToggle({
    Name = "Auto Sell",
    CurrentValue = false,
    Callback = function(v)
        autoSell = v
    end
})

-- Player Tab
PlayerTab:CreateSection("Movement")

PlayerTab:CreateSlider({
    Name = "Walk Speed",
    Range = {16, 300},
    Increment = 4,
    Suffix = "Speed",
    CurrentValue = 16,
    Callback = function(v)
        walkSpeed = v
        local hum = getHumanoid()
        if hum then hum.WalkSpeed = v end
    end
})

PlayerTab:CreateSlider({
    Name = "Jump Power",
    Range = {50, 400},
    Increment = 10,
    Suffix = "Power",
    CurrentValue = 50,
    Callback = function(v)
        jumpPower = v
        local hum = getHumanoid()
        if hum then hum.JumpPower = v end
    end
})

PlayerTab:CreateToggle({
    Name = "Infinite Jump",
    CurrentValue = false,
    Callback = function(v)
        infiniteJump = v
        setupInfJump()
    end
})

-- Misc Tab
MiscTab:CreateSection("Utility")

MiscTab:CreateToggle({
    Name = "Anti-AFK",
    CurrentValue = false,
    Callback = function(v)
        antiAFK = v
        if v then
            local vu = game:GetService("VirtualUser")
            plr.Idled:Connect(function()
                if antiAFK then
                    vu:CaptureController()
                    vu:ClickButton2(Vector2.new())
                end
            end)
        end
    end
})

-- Character added (respawn / speed & jump reset)
plr.CharacterAdded:Connect(function(char)
    wait(0.5)
    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        hum.WalkSpeed = walkSpeed
        hum.JumpPower = jumpPower
    end
end)

-- Initial setup
setupInfJump()
if plr.Character then
    local hum = getHumanoid()
    if hum then
        hum.WalkSpeed = walkSpeed
        hum.JumpPower = jumpPower
    end
end

Rayfield:LoadConfiguration()
Rayfield:Notify({
    Title = "Script Loaded",
    Content = "Update remote names yourself - most are probably different now.",
    Duration = 6
})
