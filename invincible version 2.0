-- Invincible Paid – FIXED Fluent UI (dawid-scripts original) – March 2026
-- No whitelist | All features working | Error handling | Live stats + timer

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")
local RSvc = game:GetService("RunService")
local VU = game:GetService("VirtualUser")
local WS = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

-- Load Fluent (stable original – works 2026)
local Fluent
pcall(function()
    Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
end)

if not Fluent then
    warn("Failed to load Fluent UI! Executor may block GitHub or URL changed.")
    return  -- Stop script if UI can't load
end

-- Optional SaveManager (saves toggles)
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()

-- Create Window
local Window = Fluent:CreateWindow({
    Title = "Invincible Paid",
    SubTitle = "Fixed 2026 Edition – No Whitelist",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,          -- Disable if FPS issues / detection
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Main     = Window:AddTab({Title = "Main", Icon = ""}),
    Rebirth  = Window:AddTab({Title = "Rebirth", Icon = ""}),
    Teleport = Window:AddTab({Title = "Teleport", Icon = ""}),
    Kill     = Window:AddTab({Title = "Kill", Icon = ""}),
    Stats    = Window:AddTab({Title = "Stats", Icon = ""}),
    Credits  = Window:AddTab({Title = "Credits", Icon = ""})
}

-- Globals
getgenv().NexusRunning = true

local states = {
    AutoPushups = false, AutoWeight = false, AutoHandstands = false,
    FastPunch = false, FastStrength = false, InfiniteJump = false,
    AutoRebirth = false, AutoRebirthTarget = false,
    KillAura = false, AutoKillSelected = false, AntiAfk = false
}

local targetRebirths = 1
local selectedTarget = nil

getgenv().rockFarmActive = false
getgenv().selectedRockDurability = 0

local muscleEvent = RS:FindFirstChild("muscleEvent", true)
local rebirthRemote = RS:FindFirstChild("rEvents", true) and RS.rEvents:FindFirstChild("rebirthRemote")

local sessionStart = os.time()

-- Helpers
local function tpTo(pos)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart
        if hrp then hrp.CFrame = CFrame.new(pos) end
    end)
end

local function startAutoRep(toolName, key)
    task.spawn(function()
        while states[key] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then task.wait(1.5) return end
                local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
                if tool and tool.Parent ~= char then char.Humanoid:EquipTool(tool) end
                if muscleEvent then muscleEvent:FireServer("rep") end
            end)
            task.wait(0.08)
        end
    end)
end

local fastConn
local function toggleFastStr(v)
    states.FastStrength = v
    if v then
        if fastConn then fastConn:Disconnect() end
        fastConn = RSvc.Heartbeat:Connect(function()
            pcall(function()
                if muscleEvent then
                    muscleEvent:FireServer("rep")
                    muscleEvent:FireServer("punch", "rightHand")
                    muscleEvent:FireServer("punch", "leftHand")
                end
                local t = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if t then t:Activate() end
            end)
        end)
    else
        if fastConn then fastConn:Disconnect() fastConn = nil end
    end
end

local jumpConn
local function toggleInfJump(v)
    states.InfiniteJump = v
    if v then
        jumpConn = UIS.JumpRequest:Connect(function()
            pcall(function()
                local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if h then h:ChangeState("Jumping") end
            end)
        end)
    else
        if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    end
end

local afkConn
local function toggleAntiAfk(v)
    states.AntiAfk = v
    if v then
        afkConn = LocalPlayer.Idled:Connect(function()
            VU:CaptureController()
            VU:ClickButton2(Vector2.new())
        end)
    else
        if afkConn then afkConn:Disconnect() afkConn = nil end
    end
end

local function killPlr(plr)
    pcall(function()
        local me = LocalPlayer.Character
        local them = plr.Character
        if not me or not them then return end
        local hrp = me.HumanoidRootPart
        local thrp = them.HumanoidRootPart
        if hrp and thrp then hrp.CFrame = thrp.CFrame * CFrame.new(0,-25,0) end
    end)
end

-- Main Tab
local secTools = Tabs.Main:AddSection("Tools")

secTools:AddToggle("Auto Pushups", {Title = "Auto Pushups", Default = false, Callback = function(v) states.AutoPushups = v if v then startAutoRep("Pushups", "AutoPushups") end end})
secTools:AddToggle("Auto Weight", {Title = "Auto Weight", Default = false, Callback = function(v) states.AutoWeight = v if v then startAutoRep("Weight", "AutoWeight") end end})
secTools:AddToggle("Auto Handstands", {Title = "Auto Handstands", Default = false, Callback = function(v) states.AutoHandstands = v if v then startAutoRep("Handstands", "AutoHandstands") end end})

secTools:AddToggle("Fast Strength", {Title = "Fast Strength", Default = false, Callback = toggleFastStr})
secTools:AddToggle("Fast Punch", {Title = "Fast Punch", Default = false, Callback = function(v)
    states.FastPunch = v
    if v then task.spawn(function()
        while states.FastPunch and getgenv().NexusRunning do
            pcall(function()
                if muscleEvent then
                    muscleEvent:FireServer("punch", "rightHand")
                    muscleEvent:FireServer("punch", "leftHand")
                end
                local char = LocalPlayer.Character
                local p = char and (char.Punch or LocalPlayer.Backpack.Punch)
                if p and p.Parent ~= char then char.Humanoid:EquipTool(p) end
                if p and p.Parent == char then
                    local atk = p:FindFirstChild("attackTime")
                    if atk and atk:IsA("NumberValue") then atk.Value = 0.01 end
                    p:Activate()
                end
            end)
            task.wait(0.09)
        end
    end) end
end})

secTools:AddToggle("Infinite Jump", {Title = "Infinite Jump", Default = false, Callback = toggleInfJump})
secTools:AddToggle("Anti-AFK", {Title = "Anti-AFK", Default = false, Callback = toggleAntiAfk})

secTools:AddButton({Title = "Anti Lag (FPS Boost)", Callback = function()
    Lighting.GlobalShadows = false
    Lighting.Brightness = 1
    Lighting.ClockTime = 12
    Lighting.FogEnd = 9999
    for _,v in WS:GetDescendants() do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("SunRaysEffect") then
            v.Enabled = false
        end
    end
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Fluent:Notify({Title="Anti-Lag", Content="Applied – check your FPS!", Duration=4})
end})

-- Rock Farm Section
local secRock = Tabs.Main:AddSection("Rock Farm")

local rocks = {
    {name="Tiny Island (0)", dur=0},
    {name="Starter (100)", dur=100},
    {name="Legend Beach (5k)", dur=5000},
    {name="Frost Gym (150k)", dur=150000},
    {name="Mythical (400k)", dur=400000},
    {name="Eternal (750k)", dur=750000},
    {name="Legend Gym (1M)", dur=1000000},
    {name="Muscle King (5M)", dur=5000000},
    {name="Ancient Jungle (10M)", dur=10000000}
}

for _,r in rocks do
    secRock:AddToggle("Farm "..r.name, {Title = "Farm "..r.name, Callback = function(v)
        if v then getgenv().selectedRockDurability = r.dur getgenv().rockFarmActive = true
        else if getgenv().selectedRockDurability == r.dur then getgenv().rockFarmActive = false getgenv().selectedRockDurability = 0 end end
    end})
end

secRock:AddButton({Title = "STOP All Rock Farm", Callback = function()
    getgenv().rockFarmActive = false getgenv().selectedRockDurability = 0
    Fluent:Notify({Title="Rock Farm", Content="Stopped.", Duration=3})
end})

-- Rock loop
task.spawn(function()
    while getgenv().NexusRunning do
        if not getgenv().rockFarmActive or getgenv().selectedRockDurability <= 0 then task.wait(0.6) continue end
        pcall(function()
            local c = LocalPlayer.Character
            if not c or not c:FindFirstChild("Humanoid") or c.Humanoid.Health <= 0 then task.wait(1.2) return end
            local dur = LocalPlayer:FindFirstChild("Durability")
            if not dur or dur.Value < getgenv().selectedRockDurability then task.wait(0.5) return end
            local hum = c.Humanoid
            local p = c:FindFirstChild("Punch") or LocalPlayer.Backpack:FindFirstChild("Punch")
            if hum and p and p.Parent ~= c then hum:EquipTool(p) end
            for _,o in WS.machinesFolder:GetDescendants() do
                if o.Name == "neededDurability" and o:IsA("IntValue") and o.Value == getgenv().selectedRockDurability then
                    local rock = o.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        if c:FindFirstChild("RightHand") then firetouchinterest(rock, c.RightHand, 0) task.wait(0.025) firetouchinterest(rock, c.RightHand, 1) end
                        if c:FindFirstChild("LeftHand") then firetouchinterest(rock, c.LeftHand, 0) task.wait(0.025) firetouchinterest(rock, c.LeftHand, 1) end
                        if muscleEvent then muscleEvent:FireServer("punch","leftHand") muscleEvent:FireServer("punch","rightHand") end
                    end
                end
            end
        end)
        task.wait(0.15)
    end
end)

-- Teleports
local secTP = Tabs.Teleport:AddSection("Teleports")
local tps = {
    {"Spawn/Safe", Vector3.new(-6,5,-196)},
    {"Secret", Vector3.new(1947,2,6191)},
    {"Tiny", Vector3.new(-39,6,1886)},
    {"Frozen", Vector3.new(-2623,6,-409)},
    {"Mythical", Vector3.new(2251,6,1073)},
    {"Inferno", Vector3.new(-6759,6,-1285)},
    {"Legend", Vector3.new(4603,990,-3898)},
    {"Muscle King", Vector3.new(-8626,16,-5730)},
    {"Jungle", Vector3.new(-8642,6,2381)},
    {"Lava Brawl", Vector3.new(4471,119,-8836)},
    {"Desert Brawl", Vector3.new(960,17,-7398)},
    {"Beach Brawl", Vector3.new(-1849,20,-6335)}
}
for _,t in tps do
    secTP:AddButton({Title = t[1], Callback = function() tpTo(t[2]) Fluent:Notify({Title="TP", Content="Teleported to "..t[1], Duration=3}) end})
end

-- Kill Tab
local secKill = Tabs.Kill:AddSection("Kill")

secKill:AddToggle("Kill Aura All", {Title = "Kill Aura (Everyone)", Callback = function(v)
    states.KillAura = v
    if v then task.spawn(function()
        while states.KillAura and getgenv().NexusRunning do
            for _,p in Players:GetPlayers() do if p ~= LocalPlayer then killPlr(p) end end
            task.wait(0.12)
        end
    end) end
end})

local targetDropdown = secKill:AddDropdown("Target Player", {
    Title = "Select Target",
    Values = {},
    Multi = false,
    Default = 1,
    Callback = function(v) selectedTarget = v end
})

secKill:AddToggle("Auto Kill Target", {Title = "Auto Kill Selected", Callback = function(v)
    states.AutoKillSelected = v
    if v and selectedTarget then task.spawn(function()
        while states.AutoKillSelected and getgenv().NexusRunning do
            local p = Players:FindFirstChild(selectedTarget)
            if p then killPlr(p) end
            task.wait(0.12)
        end
    end) end
end})

-- Auto refresh player list
task.spawn(function()
    while true do
        local list = {}
        for _,p in Players:GetPlayers() do
            if p ~= LocalPlayer then table.insert(list, p.Name) end
        end
        targetDropdown:SetValues(list)
        task.wait(5)
    end
end)

-- Rebirth Tab
local secRB = Tabs.Rebirth:AddSection("Rebirth")

local function doRebirth()
    if rebirthRemote then pcall(function() rebirthRemote:InvokeServer("rebirthRequest") end) end
end

secRB:AddToggle("Auto Rebirth", {Title = "Auto Rebirth (Infinite)", Callback = function(v)
    states.AutoRebirth = v
    if v then task.spawn(function()
        while states.AutoRebirth and getgenv().NexusRunning do doRebirth() task.wait(0.1) end
    end) end
end})

secRB:AddInput("Target Rebirths", {Title = "Target Rebirths", Placeholder = "Number", Numeric = true, Callback = function(v)
    local n = tonumber(v) targetRebirths = n and n > 0 and n or 1
end})

secRB:AddToggle("Auto to Target", {Title = "Auto Rebirth Until Target", Callback = function(v)
    states.AutoRebirthTarget = v
    if v then task.spawn(function()
        while states.AutoRebirthTarget and getgenv().NexusRunning do
            local rb = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Rebirths")
            if rb and rb.Value >= targetRebirths then
                states.AutoRebirthTarget = false
                Fluent:Notify({Title="Rebirth", Content="Target reached!", Duration=5})
                return
            end
            doRebirth()
            task.wait(0.12)
        end
    end) end
end})

-- Stats Tab (live)
local secStats = Tabs.Stats:AddSection("Player Stats")

local statsPara = secStats:AddParagraph({Title = "Loading stats...", Content = ""})

local timerPara = Tabs.Stats:AddParagraph({Title = "Session Time", Content = "0s"})

RSvc.RenderStepped:Connect(function()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    local str = ls and ls:FindFirstChild("Strength") and ls.Strength.Value or 0
    local rb = ls and ls:FindFirstChild("Rebirths") and ls.Rebirths.Value or 0
    local kills = ls and ls:FindFirstChild("Kills") and ls.Kills.Value or 0

    statsPara:SetTitle("Stats")
    statsPara:SetContent(string.format("Strength: %s\nRebirths: %d\nKills: %d", tostring(str), rb, kills))

    local elapsed = os.time() - sessionStart
    local h = math.floor(elapsed / 3600)
    local m = math.floor((elapsed % 3600) / 60)
    local s = elapsed % 60
    timerPara:SetContent(string.format("%02d:%02d:%02d", h, m, s))
end)

-- Credits
Tabs.Credits:AddParagraph({Title = "Credits", Content = "Logic & fixes by community\nFluent UI by dawid-scripts\nEnjoy responsibly!"})

-- Save setup
if SaveManager then
    SaveManager:SetLibrary(Fluent)
    SaveManager:SetFolder("InvinciblePaid")
    SaveManager:BuildConfigSection(Tabs.Stats)  -- or any tab
    SaveManager:LoadAutoloadConfig()
end

Window:SelectTab(1)
Fluent:Notify({Title = "Loaded", Content = "Invincible Paid – Fluent UI ready!\nMinimize: Left Ctrl", Duration = 8})

print("Invincible Paid – Fully fixed & loaded with Fluent UI")
