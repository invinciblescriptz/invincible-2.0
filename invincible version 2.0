-- Invincible Free - Safer 2026 version
-- Use on alt | Test slowly | Avoid enabling everything at once

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer

-- Random UI color
local r = math.random(60, 220)
local g = math.random(60, 220)
local b = math.random(60, 220)
local randomColor = Color3.fromRGB(r, g, b)

-- UI Library (keep if it still loads; fallback to another if broken)
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/memejames/elerium-v2-ui-library/main/Library", true))()

local window = library:AddWindow("Invincible Free (2026 Safe)", {
    main_color = randomColor,
    min_size = Vector2.new(480, 480),
    can_resize = false,
    background_transparency = 0.95,
})

getgenv().NexusRunning = true

local states = {
    AutoPushups = false,
    AutoWeight = false,
    AutoHandstands = false,
    FastPunch = false,
    InfiniteJump = false,
    AutoRebirth = false,
    AutoRebirthTarget = false,
    AntiAfk = false,
    RockFarm = false,
}

local targetRebirths = 1
getgenv().rockFarmActive = false
getgenv().selectedRockDurability = 0

-- Helpers
local muscleEvent = ReplicatedStorage:FindFirstChild("muscleEvent", true)  -- may be renamed/moved

local function safeTp(pos)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))  -- slight offset to avoid stuck
        end
    end)
end

local function equipAndActivate(toolName)
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then return end
        
        local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
        if tool then
            if tool.Parent ~= char then
                char.Humanoid:EquipTool(tool)
                task.wait(0.18)
            end
            tool:Activate()
        end
    end)
end

-- Safer auto rep (tool based, slow)
local function startAutoToolFarm(toolName, stateKey)
    task.spawn(function()
        while states[stateKey] and getgenv().NexusRunning do
            equipAndActivate(toolName)
            task.wait(0.55 + math.random(0, 80) / 100)  -- 0.55–1.35s
        end
    end)
end

-- Infinite Jump
local jumpConn
local function toggleInfiniteJump(state)
    if state then
        if jumpConn then return end
        jumpConn = UserInputService.JumpRequest:Connect(function()
            pcall(function()
                local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
            end)
        end)
    else
        if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    end
end

-- Anti-AFK
local antiAfkConn
local function toggleAntiAfk(state)
    if state then
        if antiAfkConn then return end
        antiAfkConn = LocalPlayer.Idled:Connect(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end)
    else
        if antiAfkConn then antiAfkConn:Disconnect() antiAfkConn = nil end
    end
end

-- Rock farm (very slow + randomized)
task.spawn(function()
    while getgenv().NexusRunning do
        if not getgenv().rockFarmActive or getgenv().selectedRockDurability <= 0 then
            task.wait(1.2)
            continue
        end
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char or char.Humanoid.Health <= 0 then task.wait(2.5) return end
            
            local dur = LocalPlayer:FindFirstChild("Durability")
            if not dur or dur.Value < getgenv().selectedRockDurability then
                task.wait(1.8)
                return
            end
            
            equipAndActivate("Punch")
            
            for _, obj in pairs(workspace.machinesFolder:GetDescendants()) do
                if obj.Name == "neededDurability" and obj:IsA("IntValue") and obj.Value == getgenv().selectedRockDurability then
                    local rock = obj.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("LeftHand")
                        if hand then
                            firetouchinterest(rock, hand, 0)
                            task.wait(0.09 + math.random(0, 30)/100)
                            firetouchinterest(rock, hand, 1)
                        end
                        task.wait(0.7 + math.random(20, 90)/100)  -- big delay after touch
                        break  -- one rock per cycle
                    end
                end
            end
        end)
        
        task.wait(1.1 + math.random(30, 120)/100)  -- overall cycle ~1.4–2.3s
    end
end)

local function setRockFarm(dur, enable)
    if enable then
        getgenv().selectedRockDurability = dur
        getgenv().rockFarmActive = true
    else
        if getgenv().selectedRockDurability == dur then
            getgenv().rockFarmActive = false
            getgenv().selectedRockDurability = 0
        end
    end
end

-- Safer auto rebirth
local function tryRebirth()
    pcall(function()
        local rEvents = ReplicatedStorage:FindFirstChild("rEvents")
        if rEvents and rEvents:FindFirstChild("rebirthRemote") then
            rEvents.rebirthRemote:InvokeServer("rebirthRequest")
        end
    end)
end

local rebirthLoop
local function toggleAutoRebirth(state)
    states.AutoRebirth = state
    if state then
        rebirthLoop = task.spawn(function()
            while states.AutoRebirth and getgenv().NexusRunning do
                local rebirths = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Rebirths")
                if rebirths then
                    tryRebirth()
                end
                task.wait(2.8 + math.random(100, 400)/100)  -- very slow ~3–6s
            end
        end)
    else
        if rebirthLoop then task.cancel(rebirthLoop) end
    end
end

-- UI Setup
local mainTab = window:AddTab("Main")
local rebirthTab = window:AddTab("Rebirth")
local teleportTab = window:AddTab("Teleport")
local creditsTab = window:AddTab("Credits")

local toolsFolder = mainTab:AddFolder("Auto Tools")
local rockFolder = mainTab:AddFolder("Rock Farm")

-- Tool toggles (slow tool activation)
toolsFolder:AddSwitch("Auto Pushups", function(s)
    states.AutoPushups = s
    if s then startAutoToolFarm("Pushups", "AutoPushups") end
end)

toolsFolder:AddSwitch("Auto Weight", function(s)
    states.AutoWeight = s
    if s then startAutoToolFarm("Weight", "AutoWeight") end
end)

toolsFolder:AddSwitch("Auto Handstands", function(s)
    states.AutoHandstands = s
    if s then startAutoToolFarm("Handstands", "AutoHandstands") end
end)

toolsFolder:AddSwitch("Auto Punch (Safe)", function(s)
    states.FastPunch = s
    if s then
        task.spawn(function()
            while states.FastPunch and getgenv().NexusRunning do
                equipAndActivate("Punch")
                task.wait(0.48 + math.random(20, 90)/100)
            end
        end)
    end
end)

toolsFolder:AddSwitch("Infinite Jump", toggleInfiniteJump)
toolsFolder:AddSwitch("Anti-AFK", toggleAntiAfk)

toolsFolder:AddButton("Anti-Lag (FPS Boost)", function()
    Lighting.GlobalShadows = false
    Lighting.Brightness = 1.2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 99999
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") or
           v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("SunRaysEffect") then
            v.Enabled = false
        end
    end
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

-- Teleports (mostly unchanged - still safe)
teleportTab:AddButton("Spawn / Safe", function() safeTp(Vector3.new(-6, 5, -196)) end)
teleportTab:AddButton("Secret Area", function() safeTp(Vector3.new(1947, 2, 6191)) end)
teleportTab:AddButton("Tiny Area", function() safeTp(Vector3.new(-39, 6, 1886)) end)
teleportTab:AddButton("Frozen Area", function() safeTp(Vector3.new(-2623, 6, -409)) end)
teleportTab:AddButton("Mythical Area", function() safeTp(Vector3.new(2251, 6, 1073)) end)
teleportTab:AddButton("Inferno Area", function() safeTp(Vector3.new(-6759, 6, -1285)) end)
teleportTab:AddButton("Legend Area", function() safeTp(Vector3.new(4603, 990, -3898)) end)
teleportTab:AddButton("Muscle King Area", function() safeTp(Vector3.new(-8626, 16, -5730)) end)
teleportTab:AddButton("Jungle Area", function() safeTp(Vector3.new(-8642, 6, 2381)) end)

-- Rock Farm (slow)
rockFolder:AddSwitch("Farm Tiny Island Rock (0)", function(s) setRockFarm(0, s) end)
rockFolder:AddSwitch("Farm Starter Rock (100)", function(s) setRockFarm(100, s) end)
rockFolder:AddSwitch("Farm Legend Beach Rock (5000)", function(s) setRockFarm(5000, s) end)
rockFolder:AddSwitch("Farm Frost Gym Rock (150k)", function(s) setRockFarm(150000, s) end)
rockFolder:AddSwitch("Farm Mythical Gym Rock (400k)", function(s) setRockFarm(400000, s) end)
rockFolder:AddSwitch("Farm Eternal Gym Rock (750k)", function(s) setRockFarm(750000, s) end)
rockFolder:AddSwitch("Farm Legend Gym Rock (1M)", function(s) setRockFarm(1000000, s) end)
rockFolder:AddSwitch("Farm Muscle King Rock (5M)", function(s) setRockFarm(5000000, s) end)
rockFolder:AddSwitch("Farm Ancient Jungle Rock (10M)", function(s) setRockFarm(10000000, s) end)

rockFolder:AddButton("STOP Rock Farming", function()
    getgenv().rockFarmActive = false
    getgenv().selectedRockDurability = 0
end)

-- Rebirth tab
local rebirthFolder = rebirthTab:AddFolder("Rebirth Controls")

rebirthFolder:AddSwitch("Auto Rebirth (Slow)", toggleAutoRebirth)

rebirthFolder:AddInput("Target Rebirths", function(value)
    local num = tonumber(value)
    targetRebirths = num and math.max(1, num) or 1
end)

rebirthFolder:AddSwitch("Auto Rebirth → Target", function(s)
    states.AutoRebirthTarget = s
    if s then
        task.spawn(function()
            while states.AutoRebirthTarget and getgenv().NexusRunning do
                local rebirths = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Rebirths")
                if rebirths and rebirths.Value >= targetRebirths then
                    states.AutoRebirthTarget = false
                    return
                end
                tryRebirth()
                task.wait(3.2 + math.random(80, 300)/100)
            end
        end)
    end
end)

creditsTab:AddParagraph("Note", "Use alt • Slow farming = safer • Remote spam is mostly patched in 2026")

-- Cleanup on script end (optional)
game:BindToClose(function()
    getgenv().NexusRunning = false
end)
